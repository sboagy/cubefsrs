{
    "name": "cubefsrs-sync-worker",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "deploy": "FORCE_COLOR=1 op run --env-file=\"../.env.local.template\" -- wrangler deploy",
        "dev": "FORCE_COLOR=1 op run --env-file=\"../.env.local.template\" -- wrangler dev",
        "dev:local": "WRANGLER_SEND_METRICS=false DO_NOT_TRACK=1 FORCE_COLOR=1 op run --env-file=\"../.env.local.template\" -- wrangler dev",
        "start": "FORCE_COLOR=1 op run --env-file=\"../.env.local.template\" -- wrangler dev"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20240529.0",
        "typescript": "~5.9.3",
        "wrangler": "^4.52.1"
    },
    "dependencies": {
        "oosync": "git+https://github.com/sboagy/oosync.git#main",
        "drizzle-orm": "^0.45.1",
        "jose": "^6.1.2",
        "postgres": "^3.0.0"
    }
}