# =============================================================================
# CubeFSRS SolidJS PWA - Production Build Environment Template
# =============================================================================

# This file is intentionally narrower than .env.prod.template.
# It contains only the app build-time values required for `vite build`, so CI
# build jobs do not need deploy-only secrets such as Cloudflare credentials.

# Supabase Project URL embedded into the production client bundle.
VITE_SUPABASE_URL="op://rhizome/shared-local/Supabase/SUPABASE_URL"

# Supabase anonymous key embedded into the production client bundle.
VITE_SUPABASE_ANON_KEY="op://rhizome/shared-local/Supabase/VITE_SUPABASE_ANON_KEY"

# Production sync worker URL embedded into the production client bundle.
VITE_WORKER_URL="op://rhizome/shared-local/Vite/VITE_WORKER_URL"
