{
  "name": "cubefsrs2",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- vite",
    "dev:test": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- vite --mode test",
    "build": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- vite build",
    "build:preview-local": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- vite build",
    "preview": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- vite preview",
    "preview:local": "op run --env-file=\".env.local.template\" -- vite preview --strictPort --port 4174",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome lint .",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "codegen:schema": "op run --env-file=\".env.local.template\" -- tsx node_modules/oosync/src/codegen-schema.ts --schema=cubefsrs --lenient",
    "codegen:schema:check": "tsx node_modules/oosync/src/codegen-schema.ts --schema=cubefsrs --lenient --check",
    "refresh-to-catalog-seed": "op run --env-file=\".env.local.template\" -- bash supabase/scripts/refresh_catalog_seed.sh",
    "link:local": "yalc link @rhizome/core oosync && cd worker && yalc link oosync",
    "unlink:local": "yalc remove --all && npm install && cd worker && yalc remove --all && npm install",
    "test": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- vitest run",
    "test:unit": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- vitest run tests/",
    "test:e2e": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- playwright test --reporter=list",
    "test:e2e:headed": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- playwright test --headed",
    "test:e2e:debug": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- playwright test --debug",
    "test:e2e:report": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- playwright test --reporter=html",
    "test:e2e:chromium": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- playwright test --project=chromium --reporter=list",
    "test:e2e:chromium:mobile": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- playwright test --project='Mobile Chrome' --reporter=list",
    "test:e2e:chromium:both": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- playwright test --project=chromium-auth --project=chromium --project='Mobile Chrome' --reporter=list",
    "test:e2e:chromium:both:html": "mkdir -p ./logs && FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- playwright test --project=chromium-auth --project=chromium --project='Mobile Chrome' --reporter=list,html",
    "test:e2e:chromium:html": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- playwright test --project=chromium-auth --project=chromium --reporter=list,html",
    "test:e2e:retest-failed": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- playwright test --test-list ./failures.list",
    "test:e2e:retest-failed:1": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- playwright test --workers 1 --test-list ./failures.list",
    "test:e2e:retest-failed:repeat-10": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- playwright test  --workers 8 --repeat-each 10 --test-list ./failures.list",
    "test:e2e:retest-failed:repeat-10:headed": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- playwright test  --workers 1 --repeat-each 10   --headed --test-list ./failures.list",
    "db:local:reset": "FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- playwright clear-cache && RESET_DB=true FORCE_COLOR=1 op run --env-file=\".env.local.template\" -- playwright test --reporter=list e2e/setup/auth.setup.ts --project=setup"
  },
  "dependencies": {
    "@rhizome/core": "git+https://github.com/sboagy/rhizome.git#main",
    "@solidjs/router": "^0.15.0",
    "@supabase/supabase-js": "^2.99.1",
    "@types/web-bluetooth": "^0.0.21",
    "chart.js": "^4.4.1",
    "cubing": "^0.58.2",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.45.1",
    "gan-web-bluetooth": "^3.0.2",
    "lodash-es": "^4.17.21",
    "solid-js": "^1.9.3",
    "sql.js": "^1.14.1",
    "ts-fsrs": "^5.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@playwright/test": "^1.50.0",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/user-event": "^14.5.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.7.5",
    "@types/sql.js": "^1.4.9",
    "@vitest/coverage-v8": "^3.0.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.9",
    "jsdom": "^25.0.1",
    "loglevel": "^1.9.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.8",
    "vite-plugin-solid": "^2.10.2",
    "vite-plugin-static-copy": "^3.3.0",
    "vitest": "^3.0.0",
    "oosync": "git+https://github.com/sboagy/oosync.git#main"
  }
}
